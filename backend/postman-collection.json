{
  "info": {
    "_postman_id": "capstone-image-api",
    "name": "Capstone Image API",
    "description": "Postman collection for testing the Capstone Image Sharing API\n\nAuthentication: This API uses JWT tokens. When you call the Login endpoint, Postman will automatically run a test script to extract the `accessToken` from the response and save it as a Collection Variable. The entire collection is configured to automatically use this `{{accessToken}}` in the `Authorization: Bearer <token>` header for all subsequent requests.\n\nCookies: The backend also sets `accessToken` and `refreshToken` as HTTP-only cookies, which Postman handles automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"ho_ten\": \"Nguyen Van A\",\n  \"tuoi\": 25\n}"
            },
            "url": {
              "raw": "http://localhost:3069/api/auth/register",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3069",
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Register a new user. Required fields: email, password, ho_ten. Optional: tuoi."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "    console.log(\"Access Token has been saved to collection variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3069/api/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3069",
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login user. Postman will automatically run a script to extract the accessToken and save it into Collection Variables."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:3069/api/auth/refresh",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3069",
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            },
            "description": "Refresh access token using cookies.",
            "header": []
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"accessToken\", \"\");"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:3069/api/auth/logout",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3069",
              "path": [
                "api",
                "auth",
                "logout"
              ]
            },
            "description": "Logout user and clear accessToken variable.",
            "header": []
          },
          "response": []
        }
      ]
    },
